# Copy this file to .env.local and fill in your real values.

# Neon Postgres — use the POOLED connection string (host contains "-pooler").
DATABASE_URL="postgresql://USER:PASSWORD@ep-your-endpoint-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# Admin auth (Phase 4) — single-user login.
# Generate a ready-to-paste line: npx tsx scripts/hash-password.ts "your-password"
# Every $ MUST be escaped as \$ — Next's env loader expands unescaped $.
ADMIN_PASSWORD_HASH="\$2b\$12\$REPLACE_WITH_YOUR_BCRYPT_HASH"

# Session signing secret (long random string, no $ needed). Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="replace-with-a-long-random-string-32-chars-min"

# Vercel Blob (Phase 7) — image uploads. Auto-provisioned when you connect a
# public Blob store to the project; copy the value here for local uploads.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxx"
